# ============================================================
#  .env.example  —  แม่แบบตัวแปรสภาพแวดล้อม
# ============================================================
# วิธีใช้:
#   1. ก็อปไฟล์นี้เป็น .env   ->   cp .env.example .env
#   2. เติมค่า key จริงลงใน .env  (ไฟล์ .env จะไม่ขึ้น GitHub เพราะโดน .gitignore กันไว้)
#   3. ห้ามใส่ key จริงในไฟล์ .env.example นี้ — ไฟล์นี้ขึ้น repo เป็นแค่ตัวอย่าง
# ============================================================

# --- Anthropic (Claude) — provider หลัก ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# --- Google Gemini — provider สำรอง (ใช้ Google account ส่วนตัว ไม่ใช่บัญชีมหาลัย)
# free tier กว้างกว่า Anthropic ไว้ใช้ทดสอบ agent loop จริงได้บ่อยกว่า ---
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_MODEL=gemini-flash-lite-latest

# --- Groq — ตัวเลือกไว้ทดสอบ agent loop ตอนยังไม่มี Anthropic key จริง (มี free tier) ---
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile

# --- ตั้งค่าโมเดล (ปรับได้) ---
# ตอน dev ใช้ haiku (ถูก) / ตอนรันจริง+eval ค่อยสลับเป็น sonnet
LLM_PROVIDER=anthropic
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
